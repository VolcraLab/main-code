// ---- Pin ----
// Sudah diganti dari TTP223 ke tombol 4 kaki (pull-up internal).
// Wiring: satu kaki -> GPIO 33, kaki diagonalnya -> GND (tidak perlu resistor luar)
#define TOUCH_PIN     33

#define RFID_SS_PIN   5
#define RFID_RST_PIN  32
#define RFID_SCK_PIN  25
#define RFID_MISO_PIN 26
#define RFID_MOSI_PIN 27

MFRC522 rfid(RFID_SS_PIN, RFID_RST_PIN);

// ---- Daftar kartu terdaftar (UID + nama pemilik, isi manual di sini) ----
// Cara tahu UID kartu kamu: tempel kartu di menu "Cek UID kartu" dulu,
// baca hasilnya di layar/Serial Monitor, lalu salin byte-nya ke sini.
struct RegisteredCard {
  byte uidLength;   // Panjang byte kartu (misal: 4, 7, atau 10)
  byte uid[10];     // Kapasitas menampung hingga 10 byte
  const char* name;
};

RegisteredCard registeredCards[] = {
  { 4, { 0xFA, 0xB3, 0x1C, 0x06 }, "Admin" },   // contoh -- GANTI UID dengan yang asli
  { 4, { 0x43, 0xFB, 0x0D, 0x06 }, "Member" },  // contoh -- tambah/ganti sesuai kebutuhan
  { 7, { 0x18, 0x82, 0x35, 0xD4, 0X8C, 0X99, 0XFA }, "Fadhil" },  // contoh -- tambah/ganti sesuai kebutuhan
};
const int registeredCount = sizeof(registeredCards) / sizeof(registeredCards[0]);

// Kembalikan nama pemilik kalau UID cocok, atau nullptr kalau tidak terdaftar
const char* findRegisteredName(MFRC522::Uid &uid) {
  for (int i = 0; i < registeredCount; i++) {
    // 1. Cek dulu apakah panjang UID kartu yang ditempel sama dengan data terdaftar
    if (uid.size != registeredCards[i].uidLength) {
      continue; // Jika panjang byte beda, langsung lompat ke kartu berikutnya
    }

    // 2. Cocokkan tiap byte-nya sesuai panjang uid.size
    bool match = true;
    for (int b = 0; b < uid.size; b++) {
      if (uid.uidByte[b] != registeredCards[i].uid[b]) {
        match = false;
        break;
      }
    }

    if (match) return registeredCards[i].name;
  }
  return nullptr;
}

String uidToString(MFRC522::Uid &uid) {
  String s = "";
  for (byte i = 0; i < uid.size; i++) {
    if (uid.uidByte[i] < 0x10) s += "0";
    s += String(uid.uidByte[i], HEX);
    if (i < uid.size - 1) s += ":";
  }
  s.toUpperCase();
  return s;
}

// ---- Timing sentuh ----
const unsigned long LONG_TOUCH_MS = 600; // ambang batas sentuh lama

// ---- State machine ----
enum AppState { STATE_HOME, STATE_MENU, STATE_LOGIN, STATE_CEKUID };
AppState currentState = STATE_HOME;

int menuIndex = 0; // 0 = Login, 1 = Cek UID
const char* menuLabels[2] = { "Login", "Cek UID kartu" };

// ---- Variabel deteksi sentuh (dengan debounce) ----
const unsigned long DEBOUNCE_MS = 40; // abaikan perubahan sinyal < 40ms (noise)
bool lastRawReading = LOW;
bool stableReading = LOW;
unsigned long lastChangeTime = 0;

bool touchActive = false;
unsigned long touchStartTime = 0;
bool longTouchFired = false;

void setup() {
  Serial.begin(115200);

  pinMode(TOUCH_PIN, INPUT_PULLUP); // tombol -> GND saat ditekan (aktif LOW)

  pinMode(15, OUTPUT);
  digitalWrite(15, HIGH);

  tft.init();
  tft.setRotation(3);

  SPI.begin(RFID_SCK_PIN, RFID_MISO_PIN, RFID_MOSI_PIN, RFID_SS_PIN);
  rfid.PCD_Init();

  drawHome();
}

void loop() {
  handleTouch();

  if (currentState == STATE_LOGIN) {
    runLoginLoop();
  } else if (currentState == STATE_CEKUID) {
    runCekUidLoop();
  }
}

// ============================================================
// DETEKSI SENTUH (short vs long)
// ============================================================
void handleTouch() {
  // Tombol pull-up: pin HIGH saat lepas, LOW saat ditekan -- dibalik
  // di sini supaya raw == true berarti "sedang ditekan" (konsisten
  // dengan logika debounce di bawah, sama seperti sebelumnya).
  bool raw = !digitalRead(TOUCH_PIN);

  // Kalau sinyal berubah, catat waktunya -- belum langsung dipercaya
  if (raw != lastRawReading) {
    lastChangeTime = millis();
    lastRawReading = raw;
  }

  // Baru anggap sinyal valid kalau sudah stabil selama DEBOUNCE_MS
  if ((millis() - lastChangeTime) > DEBOUNCE_MS && raw != stableReading) {
    stableReading = raw;

    if (stableReading == HIGH && !touchActive) {
      // sentuhan baru dimulai (sudah lolos debounce)
      touchActive = true;
      longTouchFired = false;
      touchStartTime = millis();
    }

    if (stableReading == LOW && touchActive) {
      // jari dilepas (sudah lolos debounce)
      if (!longTouchFired) {
        onShortTouch();
      }
      touchActive = false;
    }
  }

  // Cek long-touch selama jari masih nempel (stabil HIGH)
  if (touchActive && !longTouchFired) {
    if (millis() - touchStartTime >= LONG_TOUCH_MS) {
      longTouchFired = true;
      onLongTouch();
    }
  }
}

void onShortTouch() {
  if (currentState == STATE_MENU) {
    menuIndex = 1 - menuIndex; // toggle 0/1 (cuma 2 opsi)
    drawMenu();
  }
  // di HOME atau state program, sentuh cepat diabaikan
}

void onLongTouch() {
  switch (currentState) {
    case STATE_HOME:
      currentState = STATE_MENU;
      drawMenu();
      break;

    case STATE_MENU:
      if (menuIndex == 0) {
        currentState = STATE_LOGIN;
        enterLogin();
      } else {
        currentState = STATE_CEKUID;
        enterCekUid();
      }
      break;

    case STATE_LOGIN:
    case STATE_CEKUID:
      currentState = STATE_MENU;
      drawMenu();
      break;
  }
}

// ============================================================
// ANIMASI LOADING (dipakai di layar Login & Cek UID saat nunggu kartu)
// ============================================================
unsigned long lastAnimTime = 0;
int animPos = 0;
const int ANIM_BAR_X = 70;
const int ANIM_BAR_Y = 175;
const int ANIM_BAR_W = 100;
const int ANIM_SEG_W = 30;
const unsigned long ANIM_INTERVAL_MS = 20;

void drawAnimBarContainer() {
  tft.drawRoundRect(ANIM_BAR_X, ANIM_BAR_Y, ANIM_BAR_W, 4, 2, TFT_DARKGREY);
  animPos = 0;
  lastAnimTime = millis();
}

void updateScanAnimation() {
  if (millis() - lastAnimTime < ANIM_INTERVAL_MS) return;
  lastAnimTime = millis();

  // gambar ulang background bar lalu segmen yang bergerak
  tft.fillRoundRect(ANIM_BAR_X, ANIM_BAR_Y, ANIM_BAR_W, 4, 2, TFT_BLACK);
  tft.drawRoundRect(ANIM_BAR_X, ANIM_BAR_Y, ANIM_BAR_W, 4, 2, TFT_DARKGREY);

  int segX = ANIM_BAR_X + animPos;
  int segW = ANIM_SEG_W;
  if (segX + segW > ANIM_BAR_X + ANIM_BAR_W) {
    segW = (ANIM_BAR_X + ANIM_BAR_W) - segX;
  }
  if (segW > 0) {
    tft.fillRoundRect(segX, ANIM_BAR_Y, segW, 4, 2, TFT_CYAN);
  }

  animPos += 2;
  if (animPos > ANIM_BAR_W) animPos = 0;
}

// ============================================================
// IKON HASIL (lingkaran + centang / silang, gaya sama seperti mockup)
// ============================================================
void drawCheckIcon(int cx, int cy, int r, uint16_t color) {
  tft.drawCircle(cx, cy, r, color);
  tft.drawCircle(cx, cy, r - 1, color);
  tft.drawLine(cx - r / 2, cy, cx - r / 6, cy + r / 2, color);
  tft.drawLine(cx - r / 6, cy + r / 2, cx + r / 2, cy - r / 3, color);
}

void drawXIcon(int cx, int cy, int r, uint16_t color) {
  tft.drawCircle(cx, cy, r, color);
  tft.drawCircle(cx, cy, r - 1, color);
  tft.drawLine(cx - r / 2, cy - r / 2, cx + r / 2, cy + r / 2, color);
  tft.drawLine(cx - r / 2, cy + r / 2, cx + r / 2, cy - r / 2, color);
}

// ============================================================
// LAYAR: HOME
// ============================================================
void drawHome() {
  tft.pushImage(0, 0, 240, 240, epd_bitmap_LOGOVOLCRA_ezgif);
}

// ============================================================
// LAYAR: MENU
// ============================================================
void drawMenu() {
  tft.fillScreen(TFT_BLACK);

  for (int i = 0; i < 2; i++) {
    int y = 90 + i * 50;
    bool selected = (i == menuIndex);

    tft.drawRoundRect(30, y, 180, 40, 8, selected ? TFT_CYAN : TFT_DARKGREY);
    tft.setTextColor(selected ? TFT_CYAN : TFT_DARKGREY, TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(45, y + 12);
    tft.println(menuLabels[i]);
  }
}

// ============================================================
// STATE: LOGIN (RFID tap -> registered / not registered)
// ============================================================
bool loginResultShown = false;
unsigned long loginResultStartTime = 0;         // <--- TAMBAHAN: Catat waktu hasil mulai tampil
const unsigned long LOGIN_TIMEOUT_MS = 10000;   // <--- TAMBAHAN: Durasi tunggu (10000 ms = 10 detik)

void enterLogin() {
  loginResultShown = false;
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_CYAN, TFT_BLACK);
  tft.setTextSize(2);
  tft.setCursor(20, 100);
  tft.println("Tempelkan");
  tft.setCursor(20, 125);
  tft.println("kartu RFID");
  drawAnimBarContainer();
}

void runLoginLoop() {
  // JIKA HASIL SCAN SEDANG DITAMPILKAN:
  // Cek apakah sudah berjalan selama 10 detik
  if (loginResultShown) {
    if (millis() - loginResultStartTime >= LOGIN_TIMEOUT_MS) {
      enterLogin(); // Otomatis reset kembali ke tampilan "Tempelkan kartu RFID"
    }
    return; // Tetap abaikan pembacaan kartu baru sebelum 10 detik habis / di-reset
  }

  updateScanAnimation();

  if (!rfid.PICC_IsNewCardPresent() || !rfid.PICC_ReadCardSerial()) {
    return;
  }

  String uid = uidToString(rfid.uid);
  const char* name = findRegisteredName(rfid.uid);
  bool registered = (name != nullptr);

  Serial.print("Login - UID: ");
  Serial.print(uid);
  Serial.println(registered ? (" (terdaftar: " + String(name) + ")") : " (tidak terdaftar)");

  showLoginResult(registered, uid, name);
  
  // TANDAI HASIL SUDAH TAMPIL DAN CATAT WAKTU DIMULAINYA
  loginResultShown = true;
  loginResultStartTime = millis(); // <--- TAMBAHAN: Simpan waktu saat hasil muncul

  rfid.PICC_HaltA();
  rfid.PCD_StopCrypto1();
}

void showLoginResult(bool registered, String uid, const char* name) {
  tft.fillScreen(TFT_BLACK);
  if (registered) {
    drawCheckIcon(120, 60, 22, TFT_GREEN);
    tft.setTextColor(TFT_GREEN, TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(10, 95);
    tft.print("Hai, ");
    tft.println(name);
  } else {
    drawXIcon(120, 60, 22, TFT_RED);
    tft.setTextColor(TFT_RED, TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(10, 95);
    tft.println("Tidak terdaftar");
  }
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(1);
  tft.setCursor(10, 135);
  tft.println("UID:");
  tft.setTextSize(2);
  tft.setCursor(10, 150);
  tft.println(uid);
}

// ============================================================
// STATE: CEK UID KARTU
// ============================================================
bool cekUidResultShown = false;

void enterCekUid() {
  cekUidResultShown = false;
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_CYAN, TFT_BLACK);
  tft.setTextSize(2);
  tft.setCursor(20, 100);
  tft.println("Tempelkan");
  tft.setCursor(20, 125);
  tft.println("kartu");
  drawAnimBarContainer();
}

void runCekUidLoop() {
  if (cekUidResultShown) return;

  updateScanAnimation();

  if (!rfid.PICC_IsNewCardPresent() || !rfid.PICC_ReadCardSerial()) {
    return;
  }

  String uid = uidToString(rfid.uid);

  Serial.print("Cek UID: ");
  Serial.println(uid);

  showUidResult(uid);
  cekUidResultShown = true;

  rfid.PICC_HaltA();
  rfid.PCD_StopCrypto1();
}

void showUidResult(String uid) {
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_CYAN, TFT_BLACK);
